---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const today = new Date();
  today.setHours(23, 59, 59, 999);
  const posts = await getCollection('blog');
  return posts
    .filter(post => new Date(post.data.date) <= today)
    .map(post => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const faqs = post.data.faqs || [];
---
<Base
  title={post.data.title}
  description={post.data.description}
  date={post.data.date}
  category={post.data.category}
  author={post.data.author}
  faqs={faqs}
>
  <main>
    <article>
      <header class="article-header">
        <nav class="breadcrumb" aria-label="Fil d'Ariane">
          <a href="/">Blog Grow Lot</a>
          <span class="breadcrumb-sep">›</span>
          <span class="badge">{post.data.category}</span>
          <span class="breadcrumb-sep">›</span>
          <span>{post.data.title}</span>
        </nav>
        <h1>{post.data.title}</h1>
        <p class="article-meta">
          Par {post.data.author} &middot; {new Date(post.data.date).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}
        </p>
      </header>

      <div class="content">
        <Content />
      </div>

      {faqs.length > 0 && (
        <section class="faq-section" aria-label="Questions fréquentes">
          <h2>Questions fréquentes</h2>
          {faqs.map((faq: {q: string, a: string}) => (
            <div class="faq-item">
              <h3>{faq.q}</h3>
              <p>{faq.a}</p>
            </div>
          ))}
        </section>
      )}

      <div class="cta-box">
        <h3>Prêt à fidéliser vos clients avec Grow Lot ?</h3>
        <p>Roue de la fortune, collecte d'avis automatisée, filtre anti-avis négatifs — tout en un, à partir de 49€/mois.</p>
        <a href="https://go.grow-lot.com/cenvFVu" target="_blank" rel="noopener">Démarrer gratuitement →</a>
      </div>
    </article>
  </main>
</Base>
