---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const today = new Date();
today.setHours(23, 59, 59, 999);

const allPosts = await getCollection('blog_en');
const posts = allPosts
  .filter(post => new Date(post.data.date) <= today)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---
<Base
  title="Grow Lot Blog — Loyalty & Google Reviews Guides for Local Businesses"
  description="Practical guides to help restaurant owners and local retailers boost customer loyalty, collect Google reviews, and grow revenue."
  lang="en"
>
  <div class="hero">
    <h1>Grow your customers'<br/><em>engagement</em> 🌱</h1>
    <p>Practical guides, real-world tips and proven strategies to boost loyalty and Google reviews for your business.</p>
  </div>
  <main>
    <div class="posts-grid">
      {posts.map(post => (
        <a href={`/en/blog/${post.slug}`} class="post-card">
          <div class="post-card-top">
            <span class="badge">{post.data.category}</span>
          </div>
          <h2>{post.data.title}</h2>
          <p class="excerpt">{post.data.description}</p>
          <div class="post-card-footer">
            <span class="read-link">Read article →</span>
            <span class="post-date">{new Date(post.data.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
          </div>
        </a>
      ))}
    </div>
  </main>
</Base>
