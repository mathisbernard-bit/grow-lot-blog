---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const today = new Date();
today.setHours(23, 59, 59, 999);

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(post => new Date(post.data.date) <= today)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---
<Base
  title="Blog Grow Lot — Guides fidélisation & avis Google pour commerçants"
  description="Conseils pratiques pour fidéliser vos clients, booster vos avis Google et augmenter le chiffre d'affaires de votre commerce ou restaurant."
>
  <div class="hero">
    <h1>Faites grandir<br/><em>l'engagement</em> de vos clients 🌱</h1>
    <p>Guides terrain, stratégies testées et conseils concrets pour booster la fidélisation et les avis Google de votre commerce.</p>
  </div>
  <main>
    <div class="posts-grid">
      {posts.map(post => (
        <a href={`/blog/${post.slug}`} class="post-card">
          <div class="post-card-top">
            <span class="badge">{post.data.category}</span>
          </div>
          <h2>{post.data.title}</h2>
          <p class="excerpt">{post.data.description}</p>
          <div class="post-card-footer">
            <span class="read-link">Lire l'article →</span>
            <span class="post-date">{new Date(post.data.date).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
          </div>
        </a>
      ))}
    </div>
  </main>
</Base>
