---
const { title, description, date, category, author } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Blog Grow Lot</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="article" />
  <meta property="og:url" content={canonicalURL} />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  {date && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": title,
      "description": description,
      "datePublished": date,
      "author": { "@type": "Organization", "name": "Grow Lot" },
      "publisher": { "@type": "Organization", "name": "Grow Lot", "url": "https://grow-lot.com" }
    })} />
  )}
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Inter', sans-serif;
      background: #fff;
      color: #1a1a2e;
      line-height: 1.7;
    }
    a { color: #7c3aed; text-decoration: none; }
    a:hover { text-decoration: underline; }

    /* HEADER */
    header {
      border-bottom: 1px solid #f0eeff;
      padding: 1rem 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .logo {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-weight: 700;
      font-size: 1.1rem;
      color: #7c3aed;
    }
    .logo span { color: #1a1a2e; }
    nav a {
      margin-left: 1.5rem;
      font-size: 0.9rem;
      color: #555;
      font-weight: 500;
    }
    .cta-btn {
      background: #7c3aed;
      color: #fff !important;
      padding: 0.5rem 1.2rem;
      border-radius: 8px;
      font-weight: 600;
      font-size: 0.85rem;
      margin-left: 1.5rem;
    }
    .cta-btn:hover { background: #6d28d9; text-decoration: none !important; }

    /* MAIN */
    main { max-width: 760px; margin: 0 auto; padding: 2rem 1.5rem 4rem; }

    /* ARTICLE */
    .article-header { margin-bottom: 2.5rem; }
    .category-badge {
      display: inline-block;
      background: #f0eeff;
      color: #7c3aed;
      font-size: 0.75rem;
      font-weight: 600;
      padding: 0.3rem 0.8rem;
      border-radius: 20px;
      margin-bottom: 1rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    h1 { font-size: 2rem; line-height: 1.3; font-weight: 700; margin-bottom: 1rem; }
    .article-meta { font-size: 0.85rem; color: #888; }

    /* CONTENT */
    .content h2 { font-size: 1.4rem; font-weight: 700; margin: 2rem 0 0.75rem; color: #1a1a2e; }
    .content h3 { font-size: 1.1rem; font-weight: 600; margin: 1.5rem 0 0.5rem; color: #333; }
    .content p { margin-bottom: 1.2rem; color: #333; }
    .content ul, .content ol { margin: 0.5rem 0 1.2rem 1.5rem; }
    .content li { margin-bottom: 0.4rem; }
    .content strong { color: #1a1a2e; }
    .content blockquote {
      border-left: 4px solid #7c3aed;
      padding: 0.75rem 1.25rem;
      background: #f9f7ff;
      border-radius: 0 8px 8px 0;
      margin: 1.5rem 0;
      font-style: italic;
      color: #555;
    }

    /* CTA BOX */
    .cta-box {
      background: linear-gradient(135deg, #7c3aed 0%, #9f67fa 100%);
      color: white;
      padding: 2rem;
      border-radius: 16px;
      text-align: center;
      margin: 3rem 0 1rem;
    }
    .cta-box h3 { font-size: 1.3rem; margin-bottom: 0.75rem; color: white; }
    .cta-box p { color: rgba(255,255,255,0.85); margin-bottom: 1.25rem; font-size: 0.95rem; }
    .cta-box a {
      background: white;
      color: #7c3aed !important;
      padding: 0.75rem 2rem;
      border-radius: 8px;
      font-weight: 700;
      display: inline-block;
    }
    .cta-box a:hover { text-decoration: none; background: #f0eeff; }

    /* FOOTER */
    footer {
      border-top: 1px solid #f0eeff;
      padding: 2rem;
      text-align: center;
      font-size: 0.8rem;
      color: #aaa;
    }
    footer a { color: #7c3aed; }

    /* HOMEPAGE */
    .hero { text-align: center; padding: 3rem 0 2rem; }
    .hero h1 { font-size: 2.2rem; margin-bottom: 1rem; }
    .hero p { color: #666; font-size: 1.05rem; max-width: 500px; margin: 0 auto 2rem; }
    .articles-grid { display: grid; gap: 1.5rem; margin-top: 2rem; }
    .article-card {
      border: 1px solid #f0eeff;
      border-radius: 12px;
      padding: 1.5rem;
      transition: box-shadow 0.2s;
    }
    .article-card:hover { box-shadow: 0 4px 20px rgba(124,58,237,0.1); }
    .article-card .category-badge { margin-bottom: 0.75rem; }
    .article-card h2 { font-size: 1.15rem; margin-bottom: 0.5rem; }
    .article-card p { color: #666; font-size: 0.9rem; margin-bottom: 1rem; }
    .article-card .read-more { font-size: 0.85rem; font-weight: 600; color: #7c3aed; }
    .article-date { font-size: 0.8rem; color: #aaa; margin-top: 0.5rem; }

    @media (max-width: 600px) {
      h1 { font-size: 1.6rem; }
      header { flex-direction: column; gap: 1rem; }
    }
  </style>
</head>
<body>
  <header>
    <a href="/" class="logo">🌱 <span>Blog</span> Grow Lot</a>
    <nav>
      <a href="/">Accueil</a>
      <a href="https://grow-lot.com" target="_blank" class="cta-btn">Essayer Grow Lot</a>
    </nav>
  </header>

  <main>
    <slot />
  </main>

  <footer>
    <p>© {new Date().getFullYear()} <a href="https://grow-lot.com">Grow Lot</a> — Blog des commerçants qui fidélisent mieux.</p>
    <p style="margin-top:0.5rem">Certains liens peuvent être affiliés. <a href="https://grow-lot.com">En savoir plus</a>.</p>
  </footer>
</body>
</html>
