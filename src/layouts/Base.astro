---
const { title, description, date, category, author, faqs, lang = 'fr' } = Astro.props;
const isEN = lang === 'en';
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const logoUrl = "https://media.base44.com/images/public/69d90908f4f5dee0cdc0b7ac/7df7d4a03_Logoblanc.png";
const signupUrl = "https://go.grow-lot.com/cenvFVu";
const siteUrl = "https://grow-lot.com";
const isArticle = !!date;

const i18n = {
  blogLink: isEN ? "/en" : "/",
  ctaLabel: isEN ? "Try for free →" : "Essayer gratuitement →",
  footerText: isEN
    ? "The loyalty solution for local businesses that want to grow."
    : "La solution de fidélisation pour les commerçants qui veulent grandir.",
  footerDisclaimer: isEN
    ? "Content written by the Grow Lot team. Some links may be affiliated."
    : "Contenu rédigé par l'équipe Grow Lot. Certains liens peuvent être affiliés.",
  readMore: isEN ? "Read article →" : "Lire l'article →",
  ctaBoxTitle: isEN ? "Ready to grow customer loyalty?" : "Prêt à fidéliser vos clients avec Grow Lot ?",
  ctaBoxDesc: isEN
    ? "Lucky wheel, automated review collection, negative review filter — all in one from €49/month."
    : "Roue de la fortune, collecte d'avis automatisée, filtre anti-avis négatifs — tout en un, à partir de 49€/mois.",
  ctaBoxBtn: isEN ? "Start for free →" : "Démarrer gratuitement →",
  faqTitle: isEN ? "Frequently Asked Questions" : "Questions fréquentes",
  altLangLabel: isEN ? "🇫🇷 Version française" : "🇬🇧 English version",
  altLangHref: isEN ? "/" : "/en",
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": isEN ? "Grow Lot Blog" : "Blog Grow Lot",
  "url": isEN ? "https://blog.grow-lot.com/en" : "https://blog.grow-lot.com",
  "description": isEN
    ? "Practical guides on customer loyalty and Google reviews for local businesses."
    : "Guides pratiques de fidélisation client et avis Google pour commerçants et restaurateurs en France.",
  "publisher": {
    "@type": "Organization",
    "name": "Grow Lot",
    "url": "https://grow-lot.com",
    "logo": { "@type": "ImageObject", "url": logoUrl }
  },
  "inLanguage": isEN ? "en" : "fr-FR"
};

const articleSchema = isArticle ? {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "datePublished": date,
  "dateModified": date,
  "inLanguage": isEN ? "en" : "fr-FR",
  "url": canonicalURL,
  "author": { "@type": "Organization", "name": "Grow Lot", "url": "https://grow-lot.com" },
  "publisher": {
    "@type": "Organization",
    "name": "Grow Lot",
    "url": "https://grow-lot.com",
    "logo": { "@type": "ImageObject", "url": logoUrl }
  },
  "mainEntityOfPage": { "@type": "WebPage", "@id": canonicalURL },
  "speakable": {
    "@type": "SpeakableSpecification",
    "cssSelector": [".article-header h1", ".content p:first-of-type"]
  }
} : null;

const faqSchema = faqs && faqs.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((faq: {q: string, a: string}) => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": { "@type": "Answer", "text": faq.a }
  }))
} : null;

const breadcrumbSchema = isArticle ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": isEN ? "Grow Lot Blog" : "Blog Grow Lot", "item": isEN ? "https://blog.grow-lot.com/en" : "https://blog.grow-lot.com" },
    { "@type": "ListItem", "position": 2, "name": title, "item": canonicalURL }
  ]
} : null;
---
<!DOCTYPE html>
<html lang={isEN ? "en" : "fr"}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | {isEN ? "Grow Lot Blog" : "Blog Grow Lot"}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <meta name="author" content="Grow Lot" />
  <meta name="robots" content="index, follow" />
  <meta name="geo.region" content="FR" />
  {isEN
    ? <link rel="alternate" hreflang="fr" href={canonicalURL.toString().replace('/en', '')} />
    : <link rel="alternate" hreflang="en" href={`https://blog.grow-lot.com/en${Astro.url.pathname}`} />
  }
  <link rel="alternate" hreflang="x-default" href="https://blog.grow-lot.com" />
  <meta property="og:title" content={`${title} | Grow Lot`} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={isArticle ? "article" : "website"} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:site_name" content="Grow Lot Blog" />
  <meta property="og:locale" content={isEN ? "en_US" : "fr_FR"} />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700;800&family=Inter:wght@400;500&display=swap" rel="stylesheet" />

  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  {isArticle && <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />}
  {isArticle && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />}
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}

  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --yellow: #fdd643;
      --yellow-light: #faed3c;
      --violet: #654a98;
      --white-warm: #fffbee;
      --dark: #1a1a1a;
    }
    html { height: 100%; }
    body {
      font-family: 'Inter', sans-serif;
      background: #fff;
      color: var(--dark);
      line-height: 1.75;
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }
    h1, h2, h3, h4 { font-family: 'Poppins', sans-serif; font-weight: 700; }
    a { color: var(--violet); text-decoration: none; }
    a:hover { text-decoration: underline; }

    header {
      background: var(--violet);
      padding: 1rem 5%;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-shrink: 0;
    }
    .header-left { display: flex; align-items: center; gap: 1rem; }
    .logo img { height: 38px; width: auto; display: block; }
    .lang-switch {
      font-size: 0.78rem;
      color: rgba(255,255,255,0.7);
      font-family: 'Poppins', sans-serif;
      border: 1px solid rgba(255,255,255,0.3);
      padding: 0.25rem 0.6rem;
      border-radius: 6px;
    }
    .lang-switch:hover { color: white; border-color: white; text-decoration: none; }
    nav { display: flex; align-items: center; gap: 1.5rem; }
    nav > a {
      font-size: 0.9rem;
      color: rgba(255,255,255,0.8);
      font-weight: 500;
      font-family: 'Poppins', sans-serif;
    }
    nav > a:hover { color: white; text-decoration: none; }
    .cta-btn {
      background: var(--yellow) !important;
      color: var(--dark) !important;
      padding: 0.55rem 1.25rem;
      border-radius: 8px;
      font-weight: 700;
      font-size: 0.85rem;
      font-family: 'Poppins', sans-serif;
      white-space: nowrap;
    }
    .cta-btn:hover { background: var(--yellow-light) !important; text-decoration: none !important; }

    .hero-banner {
      background: linear-gradient(135deg, var(--violet) 0%, #8b6bb5 100%);
      color: white;
      text-align: center;
      padding: 5rem 5% 4rem;
    }
    .hero-banner h1 { font-size: 2.6rem; color: white; margin-bottom: 1rem; line-height: 1.2; }
    .hero-banner h1 span { color: var(--yellow); }
    .hero-banner p { color: rgba(255,255,255,0.85); font-size: 1.05rem; max-width: 540px; margin: 0 auto; }

    .page-body { flex: 1; display: flex; flex-direction: column; }
    main { flex: 1; width: 100%; max-width: 900px; margin: 0 auto; padding: 3rem 5% 5rem; }

    .articles-grid { display: grid; gap: 1.5rem; margin-top: 0.5rem; }
    .article-card {
      border: 2px solid #f0f0f0; border-radius: 14px;
      padding: 1.75rem 2rem; transition: all 0.2s; display: block; color: inherit;
    }
    .article-card:hover { border-color: var(--yellow); box-shadow: 0 6px 28px rgba(253,214,67,0.18); text-decoration: none; }
    .article-card h2 { font-size: 1.2rem; margin: 0.6rem 0 0.5rem; color: var(--dark); line-height: 1.3; }
    .article-card p.desc { color: #666; font-size: 0.92rem; margin-bottom: 1rem; }
    .read-more { font-size: 0.85rem; font-weight: 700; color: var(--violet); font-family: 'Poppins', sans-serif; }
    .article-date { font-size: 0.78rem; color: #aaa; margin-top: 0.6rem; }

    .category-badge {
      display: inline-block; background: var(--yellow); color: var(--dark);
      font-size: 0.70rem; font-weight: 700; padding: 0.28rem 0.8rem;
      border-radius: 20px; text-transform: uppercase; letter-spacing: 0.06em;
      font-family: 'Poppins', sans-serif;
    }

    .article-header { margin-bottom: 2.5rem; border-bottom: 2px solid #f5f5f5; padding-bottom: 1.5rem; }
    .article-header h1 { font-size: 2rem; line-height: 1.25; margin: 0.75rem 0; }
    .article-meta { font-size: 0.85rem; color: #888; }
    .breadcrumb { font-size: 0.82rem; color: #999; margin-bottom: 1rem; }
    .breadcrumb a { color: var(--violet); }
    .breadcrumb span { margin: 0 0.4rem; }

    .content h2 { font-size: 1.4rem; font-weight: 700; margin: 2.5rem 0 0.75rem; color: var(--violet); padding-bottom: 0.35rem; border-bottom: 2px solid var(--yellow); display: inline-block; }
    .content h3 { font-size: 1.05rem; font-weight: 600; margin: 1.75rem 0 0.5rem; }
    .content p { margin-bottom: 1.25rem; color: #333; }
    .content ul, .content ol { margin: 0.5rem 0 1.25rem 1.5rem; }
    .content li { margin-bottom: 0.5rem; color: #333; }
    .content strong { color: var(--dark); }
    .content a { color: var(--violet); font-weight: 500; }
    .content blockquote { border-left: 4px solid var(--yellow); padding: 0.75rem 1.25rem; background: #fffdf0; border-radius: 0 8px 8px 0; margin: 1.5rem 0; font-style: italic; color: #555; }
    .content hr { border: none; border-top: 1px solid #f0f0f0; margin: 2rem 0; }

    .faq-section { margin: 3rem 0 1rem; }
    .faq-section h2 { font-size: 1.4rem; color: var(--violet); margin-bottom: 1.5rem; border-bottom: 2px solid var(--yellow); display: inline-block; padding-bottom: 0.35rem; }
    .faq-item { border: 1px solid #f0f0f0; border-radius: 10px; padding: 1.25rem 1.5rem; margin-bottom: 0.75rem; }
    .faq-item h3 { font-size: 1rem; color: var(--dark); margin-bottom: 0.5rem; }
    .faq-item p { color: #555; font-size: 0.92rem; margin: 0; }

    .cta-box {
      background: linear-gradient(135deg, var(--violet) 0%, #8b6bb5 100%);
      color: white; padding: 2.5rem; border-radius: 16px; text-align: center;
      margin: 3.5rem 0 1rem; position: relative; overflow: hidden;
    }
    .cta-box::before { content: ''; position: absolute; top: -50px; right: -50px; width: 160px; height: 160px; background: var(--yellow); border-radius: 50%; opacity: 0.12; }
    .cta-box h3 { font-size: 1.4rem; margin-bottom: 0.75rem; color: white; }
    .cta-box p { color: rgba(255,255,255,0.85); margin-bottom: 1.5rem; font-size: 0.95rem; }
    .cta-box a { background: var(--yellow) !important; color: var(--dark) !important; padding: 0.85rem 2.2rem; border-radius: 8px; font-weight: 700; font-family: 'Poppins', sans-serif; display: inline-block; font-size: 1rem; }
    .cta-box a:hover { text-decoration: none; background: var(--yellow-light) !important; }

    footer { background: var(--dark); color: rgba(255,255,255,0.55); padding: 1.75rem 5%; text-align: center; font-size: 0.82rem; flex-shrink: 0; }
    footer a { color: var(--yellow); }

    @media (max-width: 640px) {
      .hero-banner h1 { font-size: 1.75rem; }
      .article-header h1 { font-size: 1.5rem; }
      header { padding: 1rem 4%; flex-wrap: wrap; gap: 0.75rem; }
      main { padding: 2rem 4% 4rem; }
    }
  </style>
</head>
<body>
  <header>
    <div class="header-left">
      <a href={i18n.blogLink} class="logo">
        <img src={logoUrl} alt="Grow Lot" />
      </a>
      <a href={i18n.altLangHref} class="lang-switch">{i18n.altLangLabel}</a>
    </div>
    <nav>
      <a href={i18n.blogLink}>Blog</a>
      <a href={signupUrl} target="_blank" class="cta-btn">{i18n.ctaLabel}</a>
    </nav>
  </header>

  <div class="page-body">
    <slot />
  </div>

  <footer>
    <p>© {new Date().getFullYear()} <a href={siteUrl}>Grow Lot</a> — {i18n.footerText}</p>
    <p style="margin-top:0.4rem">{i18n.footerDisclaimer}</p>
  </footer>
</body>
</html>
